<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WhiteSwan — Retention Dashboards</title>
<link href="https://fonts.googleapis.com/css2?family=Golos+Text:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #f0ede8;
  --bg2: #e8e4de;
  --card: #ffffff;
  --card2: #f7f5f2;
  --border: #ddd9d2;
  --navy: #1a2035;
  --navy2: #242d45;
  --text: #1a2035;
  --text2: #4a5568;
  --text3: #8b95a8;
  --green: #16a34a;
  --green-bg: #dcfce7;
  --green-mid: #22c55e;
  --amber: #d97706;
  --amber-bg: #fef3c7;
  --red: #dc2626;
  --red-bg: #fee2e2;
  --blue: #2563eb;
  --blue-bg: #dbeafe;
  --blue-mid: #3b82f6;
  --purple: #7c3aed;
  --purple-bg: #ede9fe;
  --teal: #0d9488;
  --teal-bg: #ccfbf1;
  --sans: 'Golos Text', sans-serif;
  --mono: 'JetBrains Mono', monospace;
}

* { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
}

/* PAGE HEADER */
.page-header {
  padding: 52px 64px 40px;
  position: relative;
}
.page-header::after {
  content:'';
  position: absolute;
  bottom: 0; left: 64px; right: 64px;
  height: 1px;
  background: var(--border);
}
.ph-label {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--text3);
  text-transform: uppercase;
  letter-spacing: .1em;
  margin-bottom: 12px;
}
.ph-title {
  font-size: 38px;
  font-weight: 800;
  letter-spacing: -.02em;
  line-height: 1.1;
  color: var(--navy);
}
.ph-title em { font-style: normal; color: var(--blue); }
.ph-sub {
  font-size: 15px;
  color: var(--text2);
  margin-top: 10px;
}
.ph-pills {
  display: flex;
  gap: 8px;
  margin-top: 20px;
  flex-wrap: wrap;
}
.pill {
  padding: 5px 14px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  border: none;
  font-family: var(--sans);
  transition: opacity .15s;
}
.pill:hover { opacity: .8; }
.pill-daily { background: #dbeafe; color: #1d4ed8; }
.pill-weekly { background: #dcfce7; color: #15803d; }
.pill-monthly { background: #fef3c7; color: #b45309; }
.pill-extra { background: #ede9fe; color: #6d28d9; }

/* SECTION */
.section {
  padding: 48px 64px 12px;
}
.section-label {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 28px;
}
.section-badge {
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 600;
  padding: 4px 12px;
  border-radius: 20px;
  text-transform: uppercase;
  letter-spacing: .08em;
}
.badge-daily { background: #dbeafe; color: #1d4ed8; }
.badge-weekly { background: #dcfce7; color: #15803d; }
.badge-monthly { background: #fef3c7; color: #b45309; }
.badge-extra { background: #ede9fe; color: #6d28d9; }

.section-title {
  font-size: 22px;
  font-weight: 700;
  letter-spacing: -.01em;
}
.section-desc {
  font-size: 13px;
  color: var(--text3);
  margin-top: 3px;
}

/* GRID */
.grid {
  display: grid;
  gap: 16px;
  margin-bottom: 16px;
}
.grid-3 { grid-template-columns: repeat(3, 1fr); }
.grid-2 { grid-template-columns: repeat(2, 1fr); }
.grid-1 { grid-template-columns: 1fr; }
.col-span-2 { grid-column: span 2; }

/* WIDGET CARD BASE */
.w {
  background: var(--card);
  border-radius: 16px;
  border: 1px solid var(--border);
  padding: 20px 22px;
  position: relative;
  overflow: hidden;
  transition: box-shadow .2s, transform .2s;
}
.w:hover {
  box-shadow: 0 8px 32px rgba(26,32,53,.08);
  transform: translateY(-1px);
}
.w-num {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--text3);
  margin-bottom: 14px;
}
.w-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--text3);
  text-transform: uppercase;
  letter-spacing: .07em;
  margin-bottom: 6px;
}
.w-title {
  font-size: 14px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 14px;
}

/* =========================================
   WIDGET 1 — Бюджет на день
   ========================================= */
.budget-day-card {
  background: linear-gradient(135deg, #1a2035 0%, #1e3a6e 100%);
  color: #fff;
  border-color: transparent;
}
.bdc-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20px;
}
.bdc-label { font-size: 12px; font-weight: 600; opacity: .6; text-transform: uppercase; letter-spacing: .07em; }
.bdc-date { font-family: var(--mono); font-size: 12px; opacity: .5; }
.bdc-amount {
  font-size: 56px;
  font-weight: 800;
  letter-spacing: -.03em;
  line-height: 1;
  margin-bottom: 4px;
}
.bdc-sub {
  font-size: 13px;
  opacity: .6;
  margin-bottom: 22px;
}
.bdc-bar-wrap {
  background: rgba(255,255,255,.12);
  border-radius: 8px;
  height: 8px;
  overflow: hidden;
  margin-bottom: 10px;
}
.bdc-bar {
  height: 100%;
  border-radius: 8px;
  background: linear-gradient(90deg, #34d399, #10b981);
  width: 58%;
}
.bdc-footer {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  opacity: .55;
}
.status-dot {
  display: inline-block;
  width: 8px; height: 8px;
  border-radius: 50%;
  margin-right: 6px;
  vertical-align: middle;
}

/* Color states - interactive */
.state-btns {
  display: flex;
  gap: 6px;
  margin-top: 14px;
}
.state-btn {
  flex: 1;
  padding: 6px 0;
  border-radius: 8px;
  font-size: 11px;
  font-weight: 600;
  border: none;
  cursor: pointer;
  font-family: var(--sans);
  opacity: .5;
  transition: opacity .15s;
}
.state-btn.active { opacity: 1; }
.state-btn.green { background: #10b981; color: #fff; }
.state-btn.yellow { background: #f59e0b; color: #fff; }
.state-btn.red { background: #ef4444; color: #fff; }

/* =========================================
   WIDGET 2 — Маскот / Лебедь
   ========================================= */
.mascot-card {
  background: linear-gradient(145deg, #fdf6e3 0%, #fef9ed 100%);
  border-color: #f0e5c0;
}
.mascot-inner {
  display: flex;
  gap: 16px;
  align-items: flex-start;
}
.swan-wrap {
  flex-shrink: 0;
  width: 72px; height: 72px;
  border-radius: 18px;
  background: linear-gradient(135deg, #fff8e1, #fff3cd);
  border: 2px solid #f0d882;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.swan-svg { font-size: 42px; line-height: 1; }
.swan-hp {
  position: absolute;
  bottom: -2px; right: -2px;
  background: #f59e0b;
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  padding: 1px 5px;
  border-radius: 10px;
  font-family: var(--mono);
}
.mascot-body { flex: 1; }
.mascot-name {
  font-size: 15px;
  font-weight: 800;
  color: #92400e;
  margin-bottom: 2px;
}
.mascot-status {
  font-size: 12px;
  color: #b45309;
  margin-bottom: 12px;
}
.streak-row {
  display: flex;
  gap: 5px;
  margin-bottom: 10px;
}
.streak-day {
  width: 28px; height: 28px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  border: 1.5px solid #f0d882;
  background: #fff8e1;
}
.streak-day.done { background: #f59e0b; border-color: #f59e0b; }
.streak-day.today { background: #fff; border-color: #f59e0b; border-width: 2px; }
.level-bar-wrap {
  background: #f0d882;
  border-radius: 6px;
  height: 6px;
  overflow: hidden;
}
.level-bar { height: 100%; background: #f59e0b; border-radius: 6px; width: 68%; }
.level-text {
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  color: #92400e;
  margin-top: 4px;
}
.badge-row {
  display: flex;
  gap: 6px;
  margin-top: 10px;
}
.badge-item {
  padding: 3px 8px;
  border-radius: 8px;
  font-size: 10px;
  font-weight: 600;
  background: #fef3c7;
  color: #92400e;
  border: 1px solid #f0d882;
}

/* =========================================
   WIDGET 3 — Ближайшие платежи
   ========================================= */
.payment-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
  gap: 10px;
}
.payment-row:last-child { border-bottom: none; padding-bottom: 0; }
.payment-icon {
  width: 36px; height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  flex-shrink: 0;
}
.payment-info { flex: 1; }
.payment-name { font-size: 13px; font-weight: 600; }
.payment-when { font-size: 11px; color: var(--text3); }
.payment-amount { font-size: 14px; font-weight: 700; text-align: right; }
.payment-status {
  font-size: 10px;
  font-weight: 600;
  padding: 2px 7px;
  border-radius: 6px;
  text-align: right;
  margin-top: 2px;
}
.status-ok { background: var(--green-bg); color: var(--green); }
.status-warn { background: var(--red-bg); color: var(--red); }
.status-near { background: var(--amber-bg); color: var(--amber); }

/* =========================================
   WIDGET 4 — Неочевидные категории
   ========================================= */
.insight-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
}
.insight-row:last-child { border-bottom: none; }
.ins-icon {
  width: 38px; height: 38px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}
.ins-body { flex: 1; }
.ins-name { font-size: 13px; font-weight: 600; }
.ins-detail { font-size: 11px; color: var(--text3); }
.ins-amount { font-size: 15px; font-weight: 700; text-align: right; }
.ins-change {
  font-size: 11px;
  font-weight: 600;
  text-align: right;
}
.change-up { color: var(--red); }
.change-dn { color: var(--green); }
.ins-cta {
  margin-top: 12px;
  background: var(--navy);
  color: #fff;
  border: none;
  padding: 9px 16px;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  width: 100%;
  font-family: var(--sans);
  transition: background .15s;
}
.ins-cta:hover { background: #2d3a5a; }

/* =========================================
   WIDGET 5 — Недельный челлендж
   ========================================= */
.challenge-card {
  background: linear-gradient(135deg, #1a2035 0%, #312e81 100%);
  color: #fff;
  border-color: transparent;
}
.ch-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16px;
}
.ch-badge {
  font-size: 10px;
  font-weight: 700;
  background: rgba(255,255,255,.15);
  padding: 3px 8px;
  border-radius: 6px;
  text-transform: uppercase;
  letter-spacing: .06em;
}
.ch-title { font-size: 18px; font-weight: 800; line-height: 1.25; margin-bottom: 6px; }
.ch-sub { font-size: 13px; opacity: .6; margin-bottom: 18px; }
.ch-progress-wrap {
  background: rgba(255,255,255,.12);
  border-radius: 8px;
  height: 10px;
  overflow: hidden;
  margin-bottom: 8px;
}
.ch-progress { height: 100%; border-radius: 8px; background: linear-gradient(90deg, #a78bfa, #7c3aed); }
.ch-footer { display: flex; justify-content: space-between; font-size: 12px; opacity: .6; }
.ch-reward {
  margin-top: 14px;
  background: rgba(255,255,255,.1);
  border-radius: 10px;
  padding: 10px 12px;
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
}
.ch-reward-icon { font-size: 22px; }

/* =========================================
   WIDGET 6 — Контроль подписок
   ========================================= */
.sub-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
}
.sub-row:last-child { border-bottom: none; }
.sub-icon {
  width: 34px; height: 34px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  flex-shrink: 0;
}
.sub-name { font-size: 13px; font-weight: 600; flex: 1; }
.sub-price { font-size: 13px; font-weight: 700; color: var(--text2); }
.sub-toggle {
  position: relative;
  width: 36px; height: 20px;
  border-radius: 10px;
  border: none;
  cursor: pointer;
  transition: background .2s;
  flex-shrink: 0;
}
.sub-toggle.on { background: var(--green-mid); }
.sub-toggle.off { background: #d1d5db; }
.sub-toggle::after {
  content: '';
  position: absolute;
  top: 2px;
  width: 16px; height: 16px;
  border-radius: 50%;
  background: #fff;
  transition: left .2s;
}
.sub-toggle.on::after { left: 18px; }
.sub-toggle.off::after { left: 2px; }
.sub-total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1.5px solid var(--border);
}
.sub-total-label { font-size: 13px; color: var(--text2); }
.sub-total-val { font-size: 18px; font-weight: 800; }
.sub-saving { font-size: 11px; font-weight: 600; color: var(--green); }

/* =========================================
   WIDGET 7 — Паттерн недели
   ========================================= */
.pattern-card {
  background: var(--card);
}
.pattern-highlight {
  background: var(--blue-bg);
  border-radius: 12px;
  padding: 14px 16px;
  margin-bottom: 14px;
}
.ph-head { font-size: 13px; font-weight: 700; color: var(--blue); margin-bottom: 6px; }
.ph-body { font-size: 14px; color: var(--navy); line-height: 1.5; }
.ph-body strong { font-weight: 800; color: var(--blue); }
.weekday-bars {
  display: flex;
  align-items: flex-end;
  gap: 5px;
  height: 64px;
  margin-bottom: 8px;
}
.wd-bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; }
.wd-bar {
  width: 100%;
  border-radius: 5px 5px 0 0;
  transition: opacity .2s;
}
.wd-bar.normal { background: #bfdbfe; }
.wd-bar.highlight { background: var(--blue); }
.wd-label { font-size: 10px; color: var(--text3); font-weight: 500; }
.wd-label.highlight { color: var(--blue); font-weight: 700; }
.pattern-year {
  font-size: 13px;
  color: var(--text2);
  background: var(--card2);
  border-radius: 8px;
  padding: 8px 12px;
}
.pattern-year strong { color: var(--text); }

/* =========================================
   WIDGET 8 — Месячный скоринг
   ========================================= */
.score-card {
  background: var(--card);
}
.score-top {
  display: flex;
  gap: 20px;
  align-items: flex-start;
  margin-bottom: 18px;
}
.score-grade {
  width: 80px; height: 80px;
  border-radius: 20px;
  background: var(--navy);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
  font-weight: 800;
  color: #fff;
  letter-spacing: -.02em;
  flex-shrink: 0;
}
.score-grade span { font-size: 22px; opacity: .7; }
.score-info { flex: 1; padding-top: 4px; }
.score-month { font-size: 13px; color: var(--text3); font-weight: 600; }
.score-title { font-size: 20px; font-weight: 800; margin-bottom: 4px; }
.score-trend { font-size: 12px; color: var(--green); font-weight: 600; }
.score-factors { display: flex; flex-direction: column; gap: 8px; }
.factor-row { display: flex; align-items: center; gap: 10px; }
.factor-label { font-size: 12px; color: var(--text2); width: 140px; flex-shrink: 0; }
.factor-bar-wrap { flex: 1; height: 6px; background: var(--bg2); border-radius: 6px; overflow: hidden; }
.factor-bar { height: 100%; border-radius: 6px; }
.f-green { background: var(--green-mid); }
.f-amber { background: #f59e0b; }
.f-blue { background: var(--blue-mid); }
.factor-pct { font-family: var(--mono); font-size: 11px; color: var(--text3); width: 32px; text-align: right; }
.score-advice {
  margin-top: 14px;
  background: #fef9c3;
  border-radius: 10px;
  padding: 10px 12px;
  font-size: 12px;
  color: #78350f;
  border-left: 3px solid #f59e0b;
}
.score-advice strong { font-weight: 700; }

/* =========================================
   WIDGET 9 — Net Worth динамика
   ========================================= */
.networth-card { background: var(--card); }
.nw-main {
  display: flex;
  gap: 20px;
  margin-bottom: 16px;
  align-items: flex-end;
}
.nw-val {
  font-size: 38px;
  font-weight: 800;
  letter-spacing: -.03em;
}
.nw-delta {
  font-size: 14px;
  font-weight: 700;
  color: var(--green);
  padding-bottom: 6px;
}
.nw-chart { position: relative; width: 100%; height: 72px; }
.nw-svg { width: 100%; height: 100%; }
.nw-months {
  display: flex;
  justify-content: space-between;
  font-size: 10px;
  color: var(--text3);
  margin-top: 4px;
  font-family: var(--mono);
}
.nw-breakdown {
  display: flex;
  gap: 10px;
  margin-top: 14px;
}
.nw-item {
  flex: 1;
  background: var(--card2);
  border-radius: 10px;
  padding: 10px 12px;
}
.nw-item-label { font-size: 11px; color: var(--text3); font-weight: 600; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 4px; }
.nw-item-val { font-size: 16px; font-weight: 700; }
.nw-item-change { font-size: 11px; font-weight: 600; margin-top: 2px; }

/* =========================================
   WIDGET 10 — Сезонное предупреждение
   ========================================= */
.seasonal-card {
  background: linear-gradient(135deg, #fff7ed 0%, #fef3c7 100%);
  border-color: #fcd34d;
}
.sea-top {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 14px;
}
.sea-icon {
  width: 44px; height: 44px;
  border-radius: 12px;
  background: #fef3c7;
  border: 1.5px solid #fcd34d;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
}
.sea-head { font-size: 15px; font-weight: 700; color: #78350f; }
.sea-sub { font-size: 12px; color: #92400e; }
.sea-timeline {
  display: flex;
  align-items: center;
  gap: 0;
  margin-bottom: 14px;
}
.sea-month {
  flex: 1;
  text-align: center;
  font-size: 10px;
  font-weight: 600;
  color: var(--text3);
  position: relative;
}
.sea-month::after {
  content: '';
  display: block;
  margin: 4px auto 0;
  width: 22px; height: 22px;
  border-radius: 50%;
  background: var(--border);
}
.sea-month.now::after { background: var(--amber); }
.sea-month.danger::after { background: #ef4444; }
.sea-month.danger { color: #ef4444; font-weight: 700; }
.sea-connector { height: 2px; background: var(--border); width: 8px; margin-top: 18px; }
.sea-advice {
  background: rgba(255,255,255,.7);
  border-radius: 10px;
  padding: 10px 12px;
  font-size: 13px;
  color: #78350f;
}
.sea-advice strong { font-weight: 700; }
.sea-saving-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10px;
  font-size: 13px;
  font-weight: 600;
  color: #78350f;
}
.sea-amount {
  font-size: 20px;
  font-weight: 800;
  color: var(--amber);
}

/* =========================================
   WIDGET 11 — Стоимость владения
   ========================================= */
.ownership-card { background: var(--card); }
.own-tabs {
  display: flex;
  gap: 6px;
  margin-bottom: 16px;
}
.own-tab {
  padding: 5px 12px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 600;
  border: 1.5px solid var(--border);
  background: var(--card2);
  color: var(--text2);
  cursor: pointer;
  transition: all .15s;
  font-family: var(--sans);
}
.own-tab.active {
