
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WhiteSwan — Главная v2</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'IBM Plex Sans',sans-serif;background:#f5f5f3;color:#1a1a1a;-webkit-font-smoothing:antialiased}
.shell{display:flex;height:100vh;max-width:1280px;margin:0 auto;background:#fff;border-left:1px solid #e8e6e1;border-right:1px solid #e8e6e1}
.sidebar{width:220px;border-right:1px solid #e8e6e1;padding:28px 0;flex-shrink:0;display:flex;flex-direction:column}
.logo{padding:0 20px 28px;display:flex;align-items:center;gap:10px}
.logo-icon{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#3a7bd5,#00d2ff)}
.logo-text{font-size:14px;font-weight:600;letter-spacing:-0.3px}
.nav{flex:1}
.nav-item{display:block;padding:10px 20px;font-size:14px;color:#6b6b6b;cursor:pointer;border-left:3px solid transparent;transition:all .15s}
.nav-item:hover{color:#1a1a1a;background:#fafaf8}
.nav-item.active{color:#2563eb;font-weight:500;border-left-color:#2563eb;background:#eff4ff}
.nav-sep{height:1px;background:#e8e6e1;margin:12px 20px}
.quick-add{margin:0 16px 20px}
.quick-add-btn{width:100%;padding:10px;background:#2563eb;color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:500;cursor:pointer;font-family:inherit}
.main{flex:1;overflow-y:auto;padding:28px 32px}
/* top bar */
.top-bar{display:flex;justify-content:space-between;align-items:center;margin-bottom:22px}
.page-title{font-size:26px;font-weight:600;letter-spacing:-.5px}
.greeting{font-size:15px;color:#888;margin-bottom:2px}
/* state switcher */
.demo-toggle{display:flex;gap:6px;margin-bottom:20px}
.demo-opt{padding:6px 14px;border-radius:8px;font-size:12px;cursor:pointer;border:1px solid #e0ddd7;background:#fff;color:#6b6b6b;font-family:inherit;transition:all .15s}
.demo-opt.active{background:#2563eb;color:#fff;border-color:#2563eb}
/* sync bar */
.sync-bar{display:flex;align-items:center;gap:8px;padding:8px 14px;background:#f4faf4;border-radius:8px;font-size:12px;color:#2e7d32}
.sdot{width:6px;height:6px;border-radius:50%;background:#66bb6a}
.stime{color:#88bfa0}
/* metrics */
.metrics{display:grid;gap:12px;margin-bottom:20px}
.m3{grid-template-columns:repeat(3,1fr)}
.m4{grid-template-columns:repeat(4,1fr)}
.metric{background:#fafaf8;border-radius:10px;padding:16px 18px;position:relative}
.metric.accent{background:#eff4ff}
.metric.empty{border:1px dashed #e0ddd7;background:#fefefe}
.metric.green-tint{background:#f0faf2}
.metric.amber-tint{background:#fef9ed}
.metric.red-tint{background:#fff5f5}
.ml{font-size:12px;color:#888;margin-bottom:6px}
.mv{font-size:24px;font-weight:600;letter-spacing:-.5px;line-height:1.2}
.mv.g{color:#16864e}.mv.r{color:#c0392b}.mv.b{color:#2563eb}.mv.ph{color:#d0cdc6;font-size:22px;font-weight:500}
.ms{font-size:11px;color:#aaa;margin-top:4px}
.mlink{font-size:11px;color:#2563eb;cursor:pointer;margin-top:6px;display:inline-block}
.mq{position:absolute;top:14px;right:14px;width:18px;height:18px;border-radius:50%;background:#f0ede8;display:flex;align-items:center;justify-content:center;font-size:10px;color:#a0a0a0;font-weight:600}
.trend{display:inline-flex;align-items:center;gap:3px;font-size:11px;font-weight:500;margin-top:4px;color:#16864e}
.trend.neg{color:#c0392b}
/* context badge on metric */
.ctx-badge{display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:500;margin-top:6px;padding:2px 8px;border-radius:6px}
.ctx-ok{background:#e8f5e9;color:#2e7d32}
.ctx-warn{background:#fff3e0;color:#e65100}
.ctx-bad{background:#fde8e8;color:#c0392b}
/* mini bar in metric */
.m-bar-wrap{height:4px;background:#e8e6e1;border-radius:2px;overflow:hidden;margin-top:10px}
.m-bar{height:100%;border-radius:2px;transition:width .3s}
/* actions */
.actions-box{border:1px solid #e8e6e1;border-radius:12px;padding:16px 18px;margin-bottom:20px}
.actions-title{font-size:15px;font-weight:500;margin-bottom:12px}
.aitem{display:flex;align-items:center;gap:12px;padding:10px 14px;border-radius:10px;margin-bottom:6px;cursor:pointer;transition:all .15s}
.aitem:last-child{margin-bottom:0}
.aitem:hover{filter:brightness(.97)}
.aitem.red{background:#fef5f5}.aitem.orange{background:#fef9ed}.aitem.blue{background:#f0f6ff}.aitem.purple{background:#f5f0ff}.aitem.green{background:#f0faf2}
.adot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.adot.red{background:#e06060}.adot.orange{background:#e6a817}.adot.blue{background:#5a9cf5}.adot.purple{background:#9575cd}.adot.green{background:#66bb6a}
.acontent{flex:1;font-size:13px}.acontent b{font-weight:500}
.asub{font-size:11px;color:#a0a0a0;margin-top:1px}
.abtn{padding:5px 12px;border-radius:7px;border:1px solid #e0ddd7;background:#fff;font-size:12px;font-weight:500;color:#2563eb;cursor:pointer;font-family:inherit;white-space:nowrap}
.abtn:hover{background:#eff4ff}
.astatus{font-size:10px;font-weight:500;padding:2px 7px;border-radius:5px;white-space:nowrap;flex-shrink:0}
.astatus.ok{background:#e8f5e9;color:#2e7d32}
.astatus.warn{background:#fde8e8;color:#c0392b}
/* two-col / three-col blocks */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px}
.three-col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:20px}
.block{border:1px solid #e8e6e1;border-radius:12px;padding:16px 18px}
.block.dashed{border-style:dashed;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;min-height:140px}
.bh{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.bt{font-size:15px;font-weight:500}
.blink{font-size:12px;color:#2563eb;cursor:pointer}
.card{background:#fafaf8;border-radius:10px;padding:12px 14px;margin-bottom:8px}
.card:last-child{margin-bottom:0}
/* goal bars */
.goal-bar{height:6px;background:#e8e6e1;border-radius:3px;overflow:hidden;margin:4px 0}
.goal-fill{height:100%;border-radius:3px}
.goal-fill.ok{background:#66bb6a}.goal-fill.behind{background:#e06060}.goal-fill.amber{background:#f59e0b}
/* progress onboarding */
.progress-wrap{background:#fff;border:1px solid #e0ddd7;border-radius:12px;padding:16px 20px;margin-bottom:20px}
.progress-bar-row{display:flex;gap:6px;margin-bottom:14px}
.pseg{flex:1;height:6px;border-radius:3px;background:#e8e6e1}
.pseg.done{background:#66bb6a}.pseg.current{background:#2563eb}
.psteps{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}
.pstep{padding:10px 14px;border-radius:10px;border:1px solid #e8e6e1;cursor:pointer}
.pstep.done{border-color:#c8e6c9;background:#f4faf4}
.pstep.current{border-color:#2563eb;background:#eff4ff}
.pstep-num{width:22px;height:22px;border-radius:50%;font-size:11px;font-weight:600;display:flex;align-items:center;justify-content:center;margin-bottom:6px}
.pstep.pending .pstep-num{background:#f5f5f3;color:#a0a0a0}
.pstep.current .pstep-num{background:#2563eb;color:#fff}
.pstep.done .pstep-num{background:#66bb6a;color:#fff}
.pstep-title{font-size:13px;font-weight:500}
.pstep.done .pstep-title{color:#2e7d32}
.pstep-sub{font-size:11px;color:#a0a0a0;margin-top:2px}
.pstep.current .pstep-sub{color:#6b8fd4}
.pstep.done .pstep-sub{color:#66bb6a}
/* btn */
.btn{padding:9px 18px;border-radius:10px;font-size:14px;font-weight:500;cursor:pointer;font-family:inherit;border:none}
.btn-p{background:#2563eb;color:#fff}.btn-s{background:#f5f5f3;color:#6b6b6b;border:1px solid #e0ddd7}

/* ═══════════════════════════════════════
   НОВЫЕ RETENTION ВИДЖЕТЫ
   ═══════════════════════════════════════ */

/* 1. Swan mascot / streak */
.mascot-block{background:linear-gradient(135deg,#fffbeb,#fef3c7);border:1px solid #f0d882;border-radius:12px;padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;gap:16px}
.swan-avatar{width:60px;height:60px;border-radius:16px;background:linear-gradient(135deg,#fff8e1,#fef3c7);border:2px solid #f0d882;display:flex;align-items:center;justify-content:center;font-size:32px;flex-shrink:0;position:relative}
.swan-level{position:absolute;bottom:-6px;right:-6px;background:#f59e0b;color:#fff;font-size:9px;font-weight:700;padding:2px 5px;border-radius:8px}
.mascot-info{flex:1}
.mascot-name{font-size:15px;font-weight:600;color:#92400e;margin-bottom:2px}
.mascot-status{font-size:12px;color:#b45309;margin-bottom:10px}
.streak-days{display:flex;gap:4px;margin-bottom:8px}
.streak-day{width:26px;height:26px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:12px;border:1.5px solid #f0d882;background:#fff8e1;color:#b45309;font-weight:500}
.streak-day.done{background:#f59e0b;border-color:#f59e0b;color:#fff}
.streak-day.today{border-color:#f59e0b;border-width:2px;background:#fff;color:#f59e0b}
.streak-lvl-bar{height:4px;background:#f0d882;border-radius:2px;overflow:hidden;margin-bottom:4px}
.streak-lvl-fill{height:100%;background:#f59e0b;border-radius:2px;width:68%}
.streak-lvl-txt{display:flex;justify-content:space-between;font-size:10px;color:#92400e}
.mascot-badges{display:flex;gap:5px;flex-wrap:wrap}
.m-badge{font-size:10px;padding:2px 7px;border-radius:6px;background:#fef3c7;color:#92400e;border:1px solid #f0d882;font-weight:500}
.mascot-right{text-align:right;flex-shrink:0}
.streak-count{font-size:36px;font-weight:700;color:#f59e0b;letter-spacing:-.02em;line-height:1}
.streak-label{font-size:11px;color:#b45309;margin-top:2px}

/* 2. Budget spidometer */
.spido-block{border:1px solid #e8e6e1;border-radius:12px;padding:20px 22px;margin-bottom:20px;position:relative;overflow:hidden;transition:border-color .3s,background .3s}
.spido-block.s-ok{background:#f0faf2;border-color:#c8e6c9}
.spido-block.s-warn{background:#fef9ed;border-color:#f0d882}
.spido-block.s-bad{background:#fef5f5;border-color:#f5c4c4}
.spido-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px}
.spido-label{font-size:12px;color:#888;margin-bottom:4px}
.spido-amount{font-size:38px;font-weight:700;letter-spacing:-.03em;line-height:1;transition:color .3s}
.spido-amount.s-ok{color:#16864e}
.spido-amount.s-warn{color:#d97706}
.spido-amount.s-bad{color:#c0392b}
.spido-sub{font-size:13px;color:#888;margin-top:4px}
.spido-status{display:flex;flex-direction:column;align-items:flex-end;gap:6px}
.spido-badge{display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:600;padding:5px 12px;border-radius:8px}
.spido-badge.ok{background:#e8f5e9;color:#2e7d32}
.spido-badge.warn{background:#fff3e0;color:#e65100}
.spido-badge.bad{background:#fde8e8;color:#c0392b}
.spido-streak{font-size:11px;color:#a0a0a0}
.spido-streak b{color:#f59e0b}
.spido-bar-wrap{height:8px;background:#e8e6e1;border-radius:4px;overflow:hidden;margin-bottom:8px}
.spido-bar{height:100%;border-radius:4px;transition:width .4s,background .3s}
.spido-bar.ok{background:linear-gradient(90deg,#34d399,#16864e)}
.spido-bar.warn{background:linear-gradient(90deg,#fbbf24,#d97706)}
.spido-bar.bad{background:linear-gradient(90deg,#f87171,#c0392b)}
.spido-footer{display:flex;justify-content:space-between;font-size:11px;color:#aaa}
.spido-btns{display:flex;gap:6px;margin-top:12px}
.spido-btn{flex:1;padding:5px 0;border-radius:7px;font-size:11px;font-weight:600;border:1.5px solid #e0ddd7;background:#fff;cursor:pointer;font-family:inherit;color:#6b6b6b;transition:all .15s}
.spido-btn.active.ok{background:#16864e;border-color:#16864e;color:#fff}
.spido-btn.active.warn{background:#d97706;border-color:#d97706;color:#fff}
.spido-btn.active.bad{background:#c0392b;border-color:#c0392b;color:#fff}

/* 3. Weekly challenge */
.challenge-block{background:linear-gradient(135deg,#1a2035,#312e81);border-radius:12px;padding:18px 20px;margin-bottom:20px;color:#fff;position:relative;overflow:hidden}
.ch-noise{position:absolute;inset:0;opacity:.04;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");pointer-events:none}
.ch-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px}
.ch-badge{font-size:10px;font-weight:600;background:rgba(255,255,255,.15);padding:3px 9px;border-radius:6px;letter-spacing:.05em}
.ch-days{font-size:11px;opacity:.5}
.ch-title{font-size:20px;font-weight:700;line-height:1.2;margin-bottom:4px}
.ch-sub{font-size:12px;opacity:.55;margin-bottom:16px}
.ch-progress-wrap{background:rgba(255,255,255,.12);border-radius:5px;height:8px;overflow:hidden;margin-bottom:8px}
.ch-progress{height:100%;border-radius:5px;background:linear-gradient(90deg,#a78bfa,#7c3aed)}
.ch-footer{display:flex;justify-content:space-between;font-size:12px;opacity:.55;margin-bottom:12px}
.ch-reward{background:rgba(255,255,255,.08);border-radius:10px;padding:10px 14px;display:flex;align-items:center;gap:10px}
.ch-reward-icon{font-size:20px}
.ch-reward-text{font-size:12px;font-weight:600}
.ch-reward-sub{font-size:11px;opacity:.5;margin-top:1px}

/* 4. Monthly scoring */
.score-block{border:1px solid #e8e6e1;border-radius:12px;padding:16px 18px;margin-bottom:20px;display:grid;grid-template-columns:auto 1fr;gap:18px;align-items:start}
.score-grade{width:72px;height:72px;border-radius:16px;background:#1a2035;display:flex;align-items:center;justify-content:center;flex-direction:column;flex-shrink:0}
.score-letter{font-size:32px;font-weight:700;color:#fff;line-height:1;letter-spacing:-.02em}
.score-plus{font-size:16px;color:rgba(255,255,255,.5);margin-top:-4px}
.score-body{padding-top:4px}
.score-month{font-size:11px;color:#a0a0a0;font-weight:500;text-transform:uppercase;letter-spacing:.06em;margin-bottom:2px}
.score-title{font-size:15px;font-weight:600;margin-bottom:2px}
.score-trend-row{font-size:11px;color:#16864e;font-weight:500;margin-bottom:12px}
.score-factors{display:flex;flex-direction:column;gap:6px}
.factor-row{display:flex;align-items:center;gap:10px}
.factor-name{font-size:12px;color:#6b6b6b;width:150px;flex-shrink:0}
.factor-bar-bg{flex:1;height:5px;background:#e8e6e1;border-radius:3px;overflow:hidden}
.factor-bar-fill{height:100%;border-radius:3px}
.fb-green{background:#66bb6a}.fb-blue{background:#5a9cf5}.fb-amber{background:#f59e0b}
.factor-pct{font-size:11px;color:#a0a0a0;width:30px;text-align:right}
.score-advice{margin-top:12px;background:#fef9ed;border-radius:8px;padding:9px 12px;font-size:12px;color:#78350f;border-left:3px solid #f59e0b}

/* 5. Daily portfolio delta */
.delta-metric{background:#1a2035;border-radius:10px;padding:16px 18px;position:relative;overflow:hidden}
.delta-label{font-size:12px;color:rgba(255,255,255,.5);margin-bottom:6px}
.delta-val{font-size:24px;font-weight:700;letter-spacing:-.04em;line-height:1.1}
.delta-val.up{color:#34d399}
.delta-val.dn{color:#f87171}
.delta-pct{font-size:13px;margin-top:4px}
.delta-pct.up{color:#34d399}.delta-pct.dn{color:#f87171}
.delta-ytd{font-size:11px;color:rgba(255,255,255,.35);margin-top:5px}
.delta-sparkline{position:absolute;bottom:0;right:0;opacity:.2}

/* 6. Market comparison - inline in portfolio block */
.market-compare{background:#f0faf2;border-radius:8px;padding:10px 12px;margin-top:10px;display:flex;align-items:center;gap:10px}
.mc-badge{font-size:10px;font-weight:600;padding:2px 7px;border-radius:5px;flex-shrink:0}
.mc-ok{background:#dcfce7;color:#15803d}
.mc-dn{background:#fee2e2;color:#991b1b}
.mc-text{font-size:12px;color:#166534;flex:1;line-height:1.4}
.mc-text.dn{color:#991b1b}

/* 7. Total effect */
.effect-block{background:#0f172a;border-radius:12px;padding:18px 20px;margin-bottom:20px;color:#fff}
.effect-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
.effect-title{font-size:14px;font-weight:600;opacity:.7}
.effect-since{font-size:11px;opacity:.35}
.effect-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.effect-item{background:rgba(255,255,255,.05);border-radius:10px;padding:10px 12px;border:1px solid rgba(255,255,255,.07)}
.ei-label{font-size:10px;opacity:.45;text-transform:uppercase;letter-spacing:.07em;margin-bottom:5px}
.ei-val{font-size:20px;font-weight:700;letter-spacing:-.02em}
.ei-val.teal{color:#34d399}.ei-val.blue{color:#60a5fa}.ei-val.amber{color:#fbbf24}.ei-val.red{color:#f87171}
.ei-sub{font-size:10px;opacity:.35;margin-top:2px}
.effect-total{background:rgba(255,255,255,.07);border-radius:10px;padding:11px 14px;border:1px solid rgba(255,255,255,.1);display:flex;justify-content:space-between;align-items:center}
.et-label{font-size:12px;opacity:.55}
.et-val{font-size:22px;font-weight:700;color:#34d399}

/* 8. Net worth mini chart in metrics */
.nw-sparkline{display:flex;align-items:flex-end;gap:2px;height:28px;margin-top:8px}
.nw-bar{border-radius:2px 2px 0 0;background:#5a9cf5;flex:1;transition:height .3s}

/* chart bars (simplified) */
.chart-box{border:1px solid #e8e6e1;border-radius:12px;padding:20px;margin-bottom:20px}
.legend{display:flex;gap:16px;margin-bottom:12px}
.legend span{display:flex;align-items:center;gap:5px;font-size:12px;color:#888}
.ldot{width:8px;height:8px;border-radius:2px;display:inline-block}
.bars{display:flex;align-items:flex-end;gap:8px;height:120px}
.bgroup{flex:1;display:flex;gap:3px;align-items:flex-end;justify-content:center}
.bar{width:14px;border-radius:3px 3px 0 0}
.bar-labels{display:flex;justify-content:space-around;margin-top:6px;font-size:10.5px;color:#aaa}
.insight{background:#eff4ff;border-radius:12px;padding:14px 18px;display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:20px}
.ins-title{font-size:14px;font-weight:500;color:#1e3a6e}
.ins-sub{font-size:12.5px;color:#5a7fb8;margin-top:3px}
.ins-btn{padding:8px 18px;background:#fff;border:1px solid #b8cfe8;border-radius:8px;font-size:13px;color:#2563eb;font-weight:500;cursor:pointer;font-family:inherit}

/* home states */
#home-newuser{display:block}
#home-active,#home-investor{display:none}

/* NEW: section divider label */
.sec-divider{display:flex;align-items:center;gap:8px;margin-bottom:14px;margin-top:4px}
.sec-divider-line{flex:1;height:1px;background:#e8e6e1}
.sec-divider-label{font-size:11px;font-weight:500;color:#a0a0a0;text-transform:uppercase;letter-spacing:.07em;white-space:nowrap}
.sec-divider-badge{font-size:10px;padding:2px 7px;border-radius:10px;font-weight:500}
.sdb-daily{background:#dbeafe;color:#1d4ed8}
.sdb-weekly{background:#dcfce7;color:#15803d}
.sdb-monthly{background:#fef3c7;color:#b45309}

/* Robo card */
.robo-card{padding:16px 18px;background:#f8faff;border:1px solid #c5d8f5;border-radius:12px;position:relative}
.robo-badge{display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:500;color:#2563eb;background:#dbeafe;padding:3px 10px;border-radius:6px;margin-bottom:10px}
.robo-title{font-size:16px;font-weight:600;color:#1e3a6e;margin-bottom:4px}
.robo-sub{font-size:13px;color:#5a7fb8;line-height:1.5;margin-bottom:14px}
