<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
let currentScenario = 'base';
let currentPeriod = 5;
let chart = null;

const scenarioMeta = {
  base: { label:'Базовый', sub:'При доходности 12%, инфляции 8%, росте дохода 5%' },
  opt:  { label:'Оптимистичный', sub:'При доходности 16%, инфляции 6%, росте дохода 8%' },
  cons: { label:'Осторожный', sub:'При доходности 8%, инфляции 10%, росте дохода 3%' }
};

function genProjection(scenario, years) {
  const start = 6.815;
  const rates = { base:1.12, opt:1.16, cons:1.08 };
  const noInv  = { base:1.04, opt:1.04, cons:1.02 };
  const r = rates[scenario];
  const n = noInv[scenario];
  const pts = years + 1;
  const labels = [];
  const main = [], lo = [], hi = [], noI = [];
  for (let i = 0; i < pts; i++) {
    labels.push(2026 + i);
    const v = +(start * Math.pow(r, i)).toFixed(2);
    main.push(v);
    lo.push(+(v * 0.88).toFixed(2));
    hi.push(+(v * 1.12).toFixed(2));
    noI.push(+(start * Math.pow(n, i)).toFixed(2));
  }
  return { labels, main, lo, hi, noI };
}

function buildChart() {
  const d = genProjection(currentScenario, currentPeriod);
  const ctx = document.getElementById('projChart').getContext('2d');

  const bandData = d.hi.map((v,i) => v - d.lo[i]);

  if (chart) chart.destroy();
  chart = new Chart(ctx, {
    data: {
      labels: d.labels,
      datasets: [
        {
          type: 'line',
          label: 'Коридор (верх)',
          data: d.hi,
          borderColor: 'transparent',
          backgroundColor: 'rgba(37,99,235,0.07)',
          fill: '+1',
          pointRadius: 0,
          tension: 0.4,
          order: 3
        },
        {
          type: 'line',
          label: 'Коридор (низ)',
          data: d.lo,
          borderColor: 'transparent',
          backgroundColor: 'rgba(37,99,235,0.07)',
          fill: false,
          pointRadius: 0,
          tension: 0.4,
          order: 4
        },
        {
          type: 'line',
          label: 'Без инвестиций',
          data: d.noI,
          borderColor: '#d0cdc6',
          borderDash: [5, 4],
          borderWidth: 1.5,
          backgroundColor: 'transparent',
          pointRadius: 0,
          tension: 0.4,
          order: 2
        },
        {
          type: 'line',
          label: scenarioMeta[currentScenario].label,
          data: d.main,
          borderColor: '#2563eb',
          borderWidth: 2.5,
          backgroundColor: 'transparent',
          pointRadius: d.main.map((_,i) => {
            if (currentPeriod <= 5) return 0;
            return 0;
          }),
          tension: 0.4,
          order: 1
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode:'index', intersect:false },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#fff',
          borderColor: '#e8e6e1',
          borderWidth: 1,
          titleColor: '#1a1a1a',
          bodyColor: '#6b6b6b',
          padding: 10,
          callbacks: {
            title: ctx => ctx[0].label + ' г.',
            label: ctx => {
              if (ctx.dataset.label.startsWith('Коридор')) return null;
              return ctx.dataset.label + ': ' + ctx.parsed.y.toFixed(1) + ' млн ₽';
            },
            filter: item => !item.dataset.label.startsWith('Коридор')
          }
        },
        annotation: { annotations: {} }
      },
      scales: {
        x: {
          grid: { color: '#f0ede8' },
          ticks: { font:{ size:12, family:"'IBM Plex Sans', sans-serif" }, color:'#a0a0a0' }
        },
        y: {
          grid: { color: '#f0ede8' },
          ticks: {
            font: { size:12, family:"'IBM Plex Sans', sans-serif" },
            color: '#a0a0a0',
            callback: v => v + ' млн'
          }
        }
      }
    }
  });
}

function setScenario(s, btn) {
  currentScenario = s;
  document.querySelectorAll('.stab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('chartSubtext').textContent = scenarioMeta[s].sub;
  buildChart();
}

function setPeriod(p, btn) {
  currentPeriod = p;
  document.querySelectorAll('.pbtn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  buildChart();
}

function toggleData(hdr) {
  const body = document.getElementById('dataBody');
