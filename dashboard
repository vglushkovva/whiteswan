<script>
function showState(state, btn) {
  document.querySelectorAll('.demo-opt').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  ['newuser','active','investor'].forEach(s => {
    document.getElementById('home-'+s).style.display = s === state ? 'block' : 'none';
  });
}

// Spidometer states
const spidoStates = {
  ok: {
    blockClass:'s-ok', amountClass:'s-ok', barClass:'ok', badgeClass:'ok',
    amount:'1 584 ₽', sub:'осталось · потрачено 1 216 ₽ из 2 800 ₽',
    badge:'✓ В зелёной зоне', barW:'43%'
  },
  warn: {
    blockClass:'s-warn', amountClass:'s-warn', barClass:'warn', badgeClass:'warn',
    amount:'320 ₽', sub:'почти лимит · потрачено 2 480 ₽ из 2 800 ₽',
    badge:'⚠ На грани', barW:'89%'
  },
  bad: {
    blockClass:'s-bad', amountClass:'s-bad', barClass:'bad', badgeClass:'bad',
    amount:'−430 ₽', sub:'перерасход · потрачено 3 230 ₽ из 2 800 ₽',
    badge:'✕ Перерасход', barW:'100%'
  }
};

function setSpido(state, clickedBtn) {
  const s = spidoStates[state];
  const block = document.getElementById('spidoBlock');
  block.className = 'spido-block ' + s.blockClass;
  const amt = document.getElementById('spidoAmount');
  amt.className = 'spido-amount ' + s.amountClass;
  amt.textContent = s.amount;
  document.getElementById('spidoSub').textContent = s.sub;
  document.getElementById('spidoBadge').className = 'spido-badge ' + s.badgeClass;
  document.getElementById('spidoBadge').textContent = s.badge;
  const bar = document.getElementById('spidoBar');
  bar.className = 'spido-bar ' + s.barClass;
  bar.style.width = s.barW;
  document.querySelectorAll('.spido-btn').forEach(b => { b.classList.remove('active','ok','warn','bad'); });
  clickedBtn.classList.add('active', state);
}
</script>
