  document.querySelectorAll('.sc-card').forEach(c => c.classList.remove('active'));
  btn.classList.add('active');
  const c = whatIfContent[type];
  document.getElementById('whatifParams').innerHTML = c.params;
  const res = document.getElementById('whatifResult');
  res.className = 'sc-result ' + c.rClass;
  res.innerHTML = c.result;
  const adv = document.getElementById('whatifAdvice');
  adv.className = 'sc-advice ' + c.advice;
  adv.innerHTML = c.adviceText;
}

